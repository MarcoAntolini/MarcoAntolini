---
/** Floating brand orbs + edge glows — v1-style ambient lights, tuned for v4 palette. */
---

<div class="site-ambient-background pointer-events-none fixed inset-x-0 top-0 z-0 h-[78dvh] overflow-hidden" aria-hidden="true">
	<div
		class="absolute -left-24 top-24 h-72 w-72 rounded-full bg-brand-emerald/14 blur-[76px]"
	>
	</div>
	<div
		class="absolute right-[-7rem] top-52 h-80 w-80 rounded-full bg-brand-teal/10 blur-[72px]"
	>
	</div>
	<div
		class="absolute left-1/2 top-12 h-px w-[min(720px,80vw)] -translate-x-1/2 bg-gradient-to-r from-transparent via-brand-emerald/45 to-transparent"
	>
	</div>
	<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-emerald/40 to-transparent"></div>
</div>
