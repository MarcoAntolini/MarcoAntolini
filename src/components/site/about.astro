---
import { getProfile } from "@/content/profile";
import { getSiteCopy } from "@/content/site-copy";
import type { Locale } from "@/lib/i18n";
import { tidy } from "@/lib/text";

interface Props {
	locale?: Locale;
}

const { locale = "en" } = Astro.props;
const profile = getProfile(locale);
const copy = getSiteCopy(locale);
const roles = profile.availabilityStatus.roles.join(" · ").toLowerCase();
---

<section id="about" class="scroll-mt-24 border-t border-brand-border/60 py-20 sm:py-28">
	<div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-start lg:gap-16">
		<div class="min-w-0">
			<h2 class="max-w-xl font-satoshi text-3xl font-bold tracking-tight text-brand-ivory sm:text-[2.4rem] sm:leading-[1.08]">
				{copy.about.heading}
			</h2>
			<div class="mt-7 space-y-5">
				{
					profile.about.map((paragraph) => (
						<p class="max-w-[62ch] text-base leading-relaxed text-brand-muted sm:text-[1.05rem]">
							{tidy(paragraph)}
						</p>
					))
				}
			</div>
		</div>

		<div class="min-w-0" aria-label={copy.about.activityLabel}>
			<div class="site-frame overflow-hidden rounded-xl">
				<div class="flex items-center gap-1.5 border-b border-brand-border bg-brand-zinc/70 px-4 py-2.5" aria-hidden="true">
					<span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]/70"></span>
					<span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]/70"></span>
					<span class="h-2.5 w-2.5 rounded-full bg-[#28c840]/70"></span>
					<span class="ml-2 font-space-mono text-[11px] text-brand-muted/80">marcoantolini/dev: ~</span>
				</div>
				<div class="grid gap-2 px-4 py-3.5 font-space-mono text-[12px] leading-[1.55] text-brand-muted sm:text-[13px]">
					<div class="min-w-0 break-words">
						<span class="text-brand-emerald">marcoantolini/dev</span> ~ % {copy.about.activityCommand}
					</div>
					<div class="grid gap-1.5 pl-3 sm:pl-5">
						{
							copy.about.building.map((line) => (
								<div class="min-w-0 break-words">
									<span class="text-brand-ivory/90">→</span> {line}
								</div>
							))
						}
					</div>
					<div class="mt-4 min-w-0 break-words">
						<span class="text-brand-emerald">marcoantolini/dev</span> ~ % {copy.about.statusCommand}
					</div>
					<div class="min-w-0 break-words">
						<span class="text-brand-emerald">● {profile.availabilityStatus.label.toLowerCase()}</span>{" — "}
						{profile.availabilityStatus.engagement.toLowerCase()}
					</div>
					<div class="min-w-0 break-words pl-3 text-brand-muted/75 sm:pl-5">{roles}</div>
					<div class="mt-4 min-w-0 break-words">
						<span class="text-brand-emerald">marcoantolini/dev</span> ~ %{" "}
						<span class="site-animate-blink inline-block h-3.5 w-2 translate-y-0.5 bg-brand-ivory/80 motion-reduce:animate-none"></span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
