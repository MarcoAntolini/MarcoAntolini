---
import { WordmarkMA } from "@/components/v3/mark";
import { profile } from "@/content/profile";

const year = new Date().getFullYear();
const links = [
	{ label: "Email", href: `mailto:${profile.email}` },
	{ label: "GitHub", href: profile.github },
	{ label: "LinkedIn", href: profile.linkedin },
	{ label: "Résumé", href: profile.cvPath },
];
---

<footer class="border-t border-brand-border/60">
	<div class="mx-auto flex max-w-[1180px] flex-col gap-8 px-5 py-12 sm:flex-row sm:items-center sm:justify-between sm:px-8">
		<div>
			<WordmarkMA client:visible />
			<p class="mt-3 max-w-xs font-space-mono text-[12px] leading-relaxed text-brand-muted">
				Build polished. Ship real.
			</p>
		</div>

		<nav aria-label="Footer" class="flex flex-wrap gap-x-6 gap-y-3">
			{
				links.map((link) => (
					<a
						href={link.href}
						target={link.href.startsWith("http") ? "_blank" : undefined}
						rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
						class="font-space-mono text-[12px] uppercase tracking-[0.14em] text-brand-muted transition-colors hover:text-brand-emerald motion-reduce:transition-none"
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
	<div class="border-t border-brand-border/60">
		<p class="mx-auto max-w-[1180px] px-5 py-5 font-space-mono text-[11px] text-brand-muted/70 sm:px-8">
			&copy; {year} Marco Antolini / Forl&igrave;-Cesena, Italy
		</p>
	</div>
</footer>
