---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
	contactDevMode,
	isDevelopment,
	rateLimitEnabled,
	shouldLogContactInsteadOfSend,
	turnstileSiteKey,
} from "@/lib/contact/config";

if (!import.meta.env.DEV) {
	return Astro.redirect("/");
}

const checks = [
	{ name: "PUBLIC_APP_ENV", ok: import.meta.env.PUBLIC_APP_ENV === "development" },
	{ name: "RESEND_API_KEY", ok: Boolean(import.meta.env.RESEND_API_KEY) },
	{ name: "Turnstile site key", ok: Boolean(turnstileSiteKey) },
	{ name: "Turnstile secret", ok: Boolean(import.meta.env.TURNSTILE_SECRET_KEY) },
	{
		name: "Upstash URL",
		ok: Boolean(import.meta.env.UPSTASH_REDIS_REST_URL && import.meta.env.UPSTASH_REDIS_REST_TOKEN),
	},
];
---

<BaseLayout title="Development dashboard" noindex>
	<main class="relative z-10 mx-auto max-w-3xl px-5 py-12 sm:px-8">
		<h1 class="font-satoshi text-3xl font-bold text-brand-ivory">Development dashboard</h1>
		<p class="mt-4 text-brand-muted">Local-only route. Not available in production builds.</p>

		<section class="mt-10">
			<h2 class="text-xl font-semibold text-brand-ivory">Environment</h2>
			<ul class="mt-4 space-y-2">
				{
					checks.map((check) => (
						<li class="flex justify-between rounded-lg border border-brand-border bg-brand-zinc/40 px-4 py-3">
							<span class="text-brand-ivory">{check.name}</span>
							<span class={check.ok ? "text-brand-emerald" : "text-brand-amber"}>{check.ok ? "OK" : "Missing"}</span>
						</li>
					))
				}
			</ul>
		</section>

		<section class="mt-10">
			<h2 class="text-xl font-semibold text-brand-ivory">Contact test mode</h2>
			<ul class="mt-4 list-disc space-y-2 pl-5 text-brand-muted">
				<li>Development mode: {isDevelopment ? "yes" : "no"}</li>
				<li>CONTACT_DEV_MODE: {contactDevMode}</li>
				<li>Log instead of send: {shouldLogContactInsteadOfSend ? "yes" : "no"}</li>
				<li>Rate limiting: {rateLimitEnabled ? "enabled" : "disabled"}</li>
			</ul>
		</section>

		<section class="mt-10">
			<h2 class="text-xl font-semibold text-brand-ivory">Routes</h2>
			<ul class="mt-4 flex flex-wrap gap-2">
				<li>
					<a href="/" class="rounded-md border border-brand-border px-3 py-2 text-sm text-brand-muted hover:border-brand-emerald/50 hover:text-brand-emerald">
						Home
					</a>
				</li>
				<li>
					<a href="/work/dracania-archives" class="rounded-md border border-brand-border px-3 py-2 text-sm text-brand-muted hover:border-brand-emerald/50 hover:text-brand-emerald">
						Case study
					</a>
				</li>
				<li>
					<a href="/#contact" class="rounded-md border border-brand-border px-3 py-2 text-sm text-brand-muted hover:border-brand-emerald/50 hover:text-brand-emerald">
						Test contact
					</a>
				</li>
			</ul>
		</section>
	</main>
</BaseLayout>
