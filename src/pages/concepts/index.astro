---
import ConceptLayout from "@/layouts/ConceptLayout.astro";
import { concepts } from "@/content/concepts";

export const prerender = true;
---

<ConceptLayout
	title="Portfolio concepts — Marco Antolini"
	description="Ten unique animated portfolio directions inspired by 1,600+ developer portfolios."
>
	<main class="min-h-screen bg-zinc-950 px-4 py-12 text-zinc-100 sm:px-8">
		<div class="mx-auto max-w-5xl">
			<div class="border-b border-zinc-800 pb-10">
				<p class="font-mono text-sm text-emerald-400">Research → 10 unique concepts</p>
				<h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">Portfolio concept gallery</h1>
				<p class="mt-4 max-w-2xl text-lg text-zinc-400">
					Inspired by patterns from
					<a
						href="https://github.com/emmabostian/developer-portfolios"
						class="text-emerald-400 underline hover:text-emerald-300"
						target="_blank"
						rel="noopener noreferrer"
					>
						emmabostian/developer-portfolios
					</a>
					(1,683 sites). Each concept trades cliché metaphors for motion, personality, and surprise — built for
					internship recruiters who've seen a hundred terminal portfolios.
				</p>
				<a href="/" class="mt-6 inline-flex text-sm text-zinc-500 hover:text-zinc-300">← Back to current portfolio</a>
			</div>

			<section class="mt-10">
				<h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500">What stood out in the research</h2>
				<ul class="mt-4 grid gap-3 sm:grid-cols-2">
					<li class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 text-sm text-zinc-400">
						<strong class="text-zinc-200">Immersive worlds</strong> — 3D adventures (gilitz.com), game levels, space
						briefings. Recruiters remember experiences, not layouts.
					</li>
					<li class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 text-sm text-zinc-400">
						<strong class="text-zinc-200">Motion typography</strong> — Tajmirul Islam, Seth Hall Creative. Giant type
						that moves with scroll beats static hero text.
					</li>
					<li class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 text-sm text-zinc-400">
						<strong class="text-zinc-200">Dual narratives</strong> — Adham Dannaway's split persona. Show student
						<em>and</em> shipper in one interaction.
					</li>
					<li class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 text-sm text-zinc-400">
						<strong class="text-zinc-200">Tactile metaphors</strong> — vinyl decks, radio dials, origami folds.
						Physical objects feel more personal than dashboards.
					</li>
				</ul>
			</section>

			<section class="mt-12">
				<h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500">Pick a direction</h2>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
					{
						concepts.map((concept, i) => (
							<a
								href={`/concepts/${concept.slug}`}
								class="group relative overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6 transition hover:border-zinc-600 hover:bg-zinc-900/70"
							>
								<div class="absolute right-4 top-4 font-mono text-3xl font-bold text-zinc-800 transition group-hover:text-zinc-700">
									{String(i + 1).padStart(2, "0")}
								</div>
								<div class="h-1 w-12 rounded-full" style={`background: ${concept.accent}`} />
								<h3 class="mt-4 font-display text-xl font-semibold text-zinc-100">{concept.name}</h3>
								<p class="mt-2 text-sm text-zinc-400">{concept.tagline}</p>
								<p class="mt-4 text-xs text-zinc-500">
									<span class="text-zinc-400">Inspired by:</span> {concept.inspiration}
								</p>
								<p class="mt-2 text-xs text-emerald-500/80 opacity-0 transition group-hover:opacity-100">
									Preview →
								</p>
							</a>
						))
					}
				</div>
			</section>
		</div>
	</main>
</ConceptLayout>
