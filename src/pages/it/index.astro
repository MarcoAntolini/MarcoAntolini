---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Footer from "@/components/site/footer.astro";
import Header from "@/components/site/header";
import Hero from "@/components/site/hero";
import Work from "@/components/site/work";
import Workshop from "@/components/site/workshop";
import Experience from "@/components/site/experience";
import Skills from "@/components/site/skills";
import About from "@/components/site/about";
import Contact from "@/components/site/contact";
import ScrollProgress from "@/components/shared/scroll-progress";

const pathname = Astro.url.pathname;
const locale = "it";
---

<BaseLayout locale={locale}>
	<div class="site-grid site-grid-fade pointer-events-none fixed inset-0 z-0" aria-hidden="true"></div>

	<ScrollProgress client:media="(min-width: 768px)" />
	<Header client:load pathname={pathname} locale={locale} />

	<div class="relative z-10">
		<div class="mx-auto max-w-[1180px] px-5 sm:px-8">
			<Hero client:idle locale={locale} />
		</div>

		<main id="main" class="mx-auto max-w-[1180px] px-5 sm:px-8">
			<Work locale={locale} />
			<Workshop locale={locale} />
			<Experience client:visible locale={locale} />
			<Skills locale={locale} />
			<About client:visible locale={locale} />
			<Contact client:visible locale={locale} />
		</main>

		<Footer locale={locale} />
	</div>
</BaseLayout>
