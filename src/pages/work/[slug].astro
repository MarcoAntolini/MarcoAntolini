---
import CaseStudy from "@/components/site/case-study";
import Footer from "@/components/site/footer.astro";
import Header from "@/components/site/header";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { caseStudies } from "@/content/case-studies";
import { getProjectBySlug } from "@/content/projects";
import { getSiteCopy } from "@/content/site-copy";
import ScrollProgress from "@/components/shared/scroll-progress.astro";

export const prerender = true;

export function getStaticPaths() {
	return caseStudies.map((study) => ({ params: { slug: study.slug } }));
}

const { slug } = Astro.params;
const locale = "en";
const project = getProjectBySlug(slug!, locale);
const caseStudy = caseStudies.find((study) => study.slug === slug);

if (!project || !caseStudy) {
	return Astro.redirect("/404");
}

const pathname = Astro.url.pathname;
const copy = getSiteCopy(locale);
---

<BaseLayout title={`${project.title} — ${copy.meta.caseStudySuffix}`} description={project.longDescription ?? project.description} locale={locale}>
	<div class="site-grid site-grid-fade pointer-events-none fixed inset-0 z-0" aria-hidden="true"></div>

	<ScrollProgress />
	<Header client:load pathname={pathname} locale={locale} />
	<main class="relative z-10 min-h-screen">
		<CaseStudy slug={slug!} locale={locale} />
	</main>
	<Footer locale={locale} />
</BaseLayout>
