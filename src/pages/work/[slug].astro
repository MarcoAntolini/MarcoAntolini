---
import V4CaseStudy from "@/components/v4/case-study";
import V4Footer from "@/components/v4/footer.astro";
import V4Header from "@/components/v4/header";
import V4Layout from "@/layouts/V4Layout.astro";
import { caseStudies } from "@/content/case-studies";
import { getProjectBySlug } from "@/content/projects";
import ScrollProgress from "@/components/portfolio/scroll-progress";

export const prerender = true;

export function getStaticPaths() {
	return caseStudies.map((study) => ({ params: { slug: study.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);
const caseStudy = caseStudies.find((study) => study.slug === slug);

if (!project || !caseStudy) {
	return Astro.redirect("/404");
}

const pathname = Astro.url.pathname;
---

<V4Layout title={`${project.title} — Case study`} description={project.longDescription ?? project.description}>
	<div class="v4-grid v4-grid-fade pointer-events-none fixed inset-0 z-0" aria-hidden="true"></div>

	<ScrollProgress client:load />
	<V4Header client:load pathname={pathname} basePath="/v4" />
	<main class="relative z-10 min-h-screen">
		<V4CaseStudy client:load slug={slug!} />
	</main>
	<V4Footer />
</V4Layout>
