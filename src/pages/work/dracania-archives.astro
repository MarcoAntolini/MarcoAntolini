---
import AmbientBackground from "@/components/portfolio/ambient-background.astro";
import DracaniaCaseStudy from "@/components/portfolio/dracania-case-study";
import SiteFooter from "@/components/portfolio/site-footer.astro";
import SiteHeader from "@/components/portfolio/site-header";
import BaseLayout from "@/layouts/BaseLayout.astro";

const pathname = Astro.url.pathname;
---

<BaseLayout
	title="Dracania Archives — Case study"
	description="How Marco Antolini built and shipped Dracania Archives, a production Next.js app for the Drakensang Online community."
>
	<AmbientBackground />
	<SiteHeader client:load pathname={pathname} />
	<main class="relative min-h-screen">
		<DracaniaCaseStudy client:load />
	</main>
	<SiteFooter />
</BaseLayout>
