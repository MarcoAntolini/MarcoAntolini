---
import V2Layout from "@/layouts/V2Layout.astro";
import V2Footer from "@/components/v2/footer.astro";
import V2Header from "@/components/v2/header";
import V2Hero from "@/components/v2/hero";
import V2Proof from "@/components/v2/proof";
import V2Work from "@/components/v2/work";
import V2ProjectsIndex from "@/components/v2/projects-index";
import V2Experience from "@/components/v2/experience";
import V2Skills from "@/components/v2/skills";
import V2About from "@/components/v2/about";
import V2Contact from "@/components/v2/contact";
---

<V2Layout title="Marco Antolini · Frontend & mobile engineer">
	<span id="v2-top-sentinel" class="absolute left-0 top-0 h-px w-px" aria-hidden="true"></span>
	<span id="top" class="absolute left-0 top-0" aria-hidden="true"></span>

	{/* Ambient blueprint grid — masked, fixed, behind content */}
	<div class="v2-grid v2-grid-fade pointer-events-none fixed inset-0 z-0" aria-hidden="true"></div>

	<V2Header client:load />

	<div class="relative z-10">
		<div class="mx-auto max-w-[1180px] px-5 sm:px-8">
			<V2Hero client:load />
		</div>

		<V2Proof client:visible />

		<main class="mx-auto max-w-[1180px] px-5 sm:px-8">
			<V2Work client:visible />
			<V2ProjectsIndex client:visible />
			<V2Experience client:visible />
			<V2Skills client:visible />
			<V2About client:visible />
			<V2Contact client:visible />
		</main>

		<V2Footer />
	</div>
</V2Layout>
