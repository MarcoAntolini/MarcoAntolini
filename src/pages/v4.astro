---
import V4Layout from "@/layouts/V4Layout.astro";
import V4Footer from "@/components/v4/footer.astro";
import V4Header from "@/components/v4/header";
import V4Hero from "@/components/v4/hero";
import V4Work from "@/components/v4/work";
import V4Workshop from "@/components/v4/workshop";
import V4Experience from "@/components/v4/experience";
import V4Skills from "@/components/v4/skills";
import V4About from "@/components/v4/about";
import V4Contact from "@/components/v4/contact";
import ScrollProgress from "@/components/portfolio/scroll-progress";

const pathname = Astro.url.pathname;
---

<V4Layout title="Marco Antolini · Frontend & mobile engineer" noindex>
	<div class="v4-grid v4-grid-fade pointer-events-none fixed inset-0 z-0" aria-hidden="true"></div>

	<ScrollProgress client:load />
	<V4Header client:load pathname={pathname} basePath="/v4" />

	<div class="relative z-10">
		<div class="mx-auto max-w-[1180px] px-5 sm:px-8">
			<V4Hero client:load />
		</div>

		<main id="main" class="mx-auto max-w-[1180px] px-5 sm:px-8">
			<V4Work client:visible />
			<V4Workshop client:visible />
			<V4Experience client:visible />
			<V4Skills client:visible />
			<V4About client:visible />
			<V4Contact client:visible />
		</main>

		<V4Footer />
	</div>
</V4Layout>
