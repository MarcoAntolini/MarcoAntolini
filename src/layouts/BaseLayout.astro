---
import DevBanner from "@/components/dev-banner";
import ToastProvider from "@/components/toast-provider";
import { profile } from "@/content/profile";
import { absoluteUrl, personJsonLd } from "@/lib/seo";
import "@/styles/global.css";

export interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
}

const defaultTitle = `${profile.name} — Frontend & mobile engineer`;
const defaultDescription = profile.heroLine;

const { title = defaultTitle, description = defaultDescription, noindex = false } = Astro.props;
const canonicalUrl = absoluteUrl(Astro.url.pathname === "/" ? "/" : Astro.url.pathname);
const jsonLd = JSON.stringify(personJsonLd());
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={profile.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Space+Grotesk:wght@300..700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-craft-bg font-body text-craft-foreground antialiased">
		<script type="application/ld+json" set:html={jsonLd} />
		<slot />
		<DevBanner client:load />
		<ToastProvider client:load />
	</body>
</html>
