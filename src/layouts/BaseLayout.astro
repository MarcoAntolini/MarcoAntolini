---
import AmbientBackground from "@/components/site/ambient-background.astro";
import CursorGlow from "@/components/shared/cursor-glow";
import AccentSwitcher from "@/components/site/accent-switcher";
import ToastProvider from "@/components/toast-provider";
import { getProfile } from "@/content/profile";
import { getSiteCopy } from "@/content/site-copy";
import { defaultLocale, localizedPath, locales, stripLocalePrefix, type Locale } from "@/lib/i18n";
import { absoluteUrl, personJsonLd } from "@/lib/seo";
import { tidy } from "@/lib/text";
import "@/styles/site.css";

export interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
	locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const profile = getProfile(locale);
const copy = getSiteCopy(locale);
const defaultTitle = `${profile.name} · ${copy.meta.title}`;
const defaultDescription = tidy(profile.heroLine);

const { title = defaultTitle, description = defaultDescription, noindex = false } = Astro.props;
const canonicalUrl = absoluteUrl(Astro.url.pathname);
const alternatePath = stripLocalePrefix(Astro.url.pathname);
const jsonLd = JSON.stringify(personJsonLd(locale));
const accentBootScript = `
(() => {
	try {
		const theme = localStorage.getItem("accent-theme");
		if (theme && theme !== "emerald") {
			document.documentElement.dataset.accentTheme = theme;
		}
	} catch {}
})();
`;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{noindex ? <meta name="robots" content="noindex, nofollow" /> : null}
		<link rel="canonical" href={canonicalUrl} />
		{
			locales.map((alternateLocale) => (
				<link rel="alternate" hreflang={alternateLocale} href={absoluteUrl(localizedPath(alternatePath, alternateLocale))} />
			))
		}
		<link rel="alternate" hreflang="x-default" href={absoluteUrl(localizedPath(alternatePath, defaultLocale))} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
		<link
			href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<script is:inline set:html={accentBootScript}></script>
	</head>
	<body class="min-h-screen bg-brand-obsidian font-satoshi text-brand-ivory antialiased">
		<script type="application/ld+json" set:html={jsonLd} />
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[80] focus:rounded-lg focus:bg-brand-emerald focus:px-4 focus:py-2 focus:font-satoshi focus:text-sm focus:font-semibold focus:text-brand-obsidian"
		>
			{copy.skipToContent}
		</a>
		<AmbientBackground />
		<CursorGlow client:load />
		<AccentSwitcher client:load />
		<slot />
		<div class="site-noise pointer-events-none fixed inset-0 z-[1] opacity-55" aria-hidden="true"></div>
		<ToastProvider client:load />
	</body>
</html>
