---
import ToastProvider from "@/components/toast-provider";
import { profile } from "@/content/profile";
import { absoluteUrl, personJsonLd } from "@/lib/seo";
import { tidy } from "@/lib/v2-text";
import "@/styles/v2.css";

export interface Props {
	title?: string;
	description?: string;
}

const defaultTitle = `${profile.name} · Frontend & mobile engineer`;
const defaultDescription = tidy(profile.heroLine);

const { title = defaultTitle, description = defaultDescription } = Astro.props;
const canonicalUrl = absoluteUrl(Astro.url.pathname);
const jsonLd = JSON.stringify(personJsonLd());
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{/* Comparison route — keep the canonical / live site as the indexable one */}
		<meta name="robots" content="noindex, nofollow" />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
		{/* Satoshi (display) from Fontshare + Space Mono (interface detail) from Google */}
		<link
			href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-v2-obsidian font-satoshi text-v2-ivory antialiased">
		<script type="application/ld+json" set:html={jsonLd} />
		{/* Fixed grain overlay — pointer-events none, never on a scroll container */}
		<div class="v2-noise pointer-events-none fixed inset-0 z-[1] opacity-60" aria-hidden="true"></div>
		<slot />
		<ToastProvider client:load />
	</body>
</html>
